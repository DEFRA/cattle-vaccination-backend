<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>APHA_DatesRequiredOnSentInvitation</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
TEXT(APHA_Status__c) = &apos;Sent&apos;,
OR(ISBLANK(APHA_DateSent__c), ISBLANK(APHA_ExpectedResponseDate__c))
)</errorConditionFormula>
    <errorMessage>Date Sent and Expected Response Date are required if Status is Sent</errorMessage>
</ValidationRule>
