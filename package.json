{
  "name": "cattle-vaccination-backend",
  "version": "0.0.0",
  "description": "cattle-vaccination-backend",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "NODE_ENV=development nodemon --env-file='.env' --inspect=0.0.0.0 --ext js,json --legacy-watch ./src",
    "format": "prettier --write \"**/*.{cjs,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{cjs,js,json,md}\"",
    "git:pre-commit-hook": "npm run security-audit && npm run format:check && npm run lint && npm test",
    "lint": "eslint --cache --cache-strategy content \"**/*.{cjs,js}\"",
    "lint:fix": "npm run lint -- --fix",
    "postinstall": "npm run setup:husky",
    "security-audit": "npm audit --audit-level=high",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "start": "NODE_ENV=production node --use-strict .",
    "test": "TZ=UTC vitest run",
    "test:coverage": "TZ=UTC vitest run --coverage",
    "test:watch": "TZ=UTC vitest"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@defra/cdp-auditing": "0.6.0",
    "@defra/hapi-secure-context": "0.4.0",
    "@defra/hapi-tracing": "1.30.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@hapi/boom": "10.0.1",
    "@hapi/hapi": "21.4.4",
    "aws-embedded-metrics": "4.2.1",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "global-agent": "3.0.0",
    "hapi-pino": "13.0.0",
    "hapi-pulse": "3.0.1",
    "https-proxy-agent": "7.0.6",
    "joi": "18.0.2",
    "pino": "10.1.0",
    "pino-pretty": "13.1.3",
    "undici": "7.24.6"
  },
  "overrides": {
    "minimatch": ">=9.0.0"
  },
  "devDependencies": {
    "@babel/core": "7.28.5",
    "@babel/preset-env": "7.28.5",
    "@vitest/coverage-v8": "4.0.16",
    "eslint": "9.39.4",
    "husky": "9.1.7",
    "neostandard": "0.11.1",
    "nodemon": "3.1.14",
    "prettier": "3.7.4",
    "vitest": "4.0.16",
    "vitest-fetch-mock": "0.4.5"
  }
}
